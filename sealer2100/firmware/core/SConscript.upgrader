    'embed/BSP_drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_pcd.c',
    'embed/BSP_drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_pcd_ex.c',
